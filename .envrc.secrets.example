# R2 (Cloudflare) S3-compatible credentials for the site deploy.
# Copy to `.envrc.secrets` (gitignored) and fill in.
# Loaded by .envrc via `source_env_if_exists`.
#
# These mirror the three GitHub Secrets consumed by
# .github/workflows/deploy.yml. Create the keys in the Cloudflare dashboard:
#   R2 → Manage R2 API Tokens → Create API Token
#   Permissions: Object Read & Write
#   Bucket:      956d0eaa1ac78d3e-williamblack-dev

# Names matching the GitHub Secrets:
export R2_ACCESS_KEY_ID=your-r2-access-key-id
export R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
export CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id

# To use `aws s3 ...` against R2 locally, also export the AWS_* aliases.
# The AWS CLI reads these names; R2 requires AWS_DEFAULT_REGION=auto
# (real AWS region names like us-east-1 are rejected).
# export AWS_ACCESS_KEY_ID="$R2_ACCESS_KEY_ID"
# export AWS_SECRET_ACCESS_KEY="$R2_SECRET_ACCESS_KEY"
# export AWS_DEFAULT_REGION=auto
